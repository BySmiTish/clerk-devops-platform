# Пример inventory — скопируй как hosts.ini или используй scripts/render-ansible-inventory
# ansible_host — Elastic IP (terraform output public_ip)
# ansible_ssh_private_key_file — путь к .pem ключу

[clerk_servers]
clerk_dev ansible_host=1.2.3.4 ansible_user=ubuntu ansible_ssh_private_key_file=~/.ssh/clerk-devops-key.pem ansible_python_interpreter=/usr/bin/python3
