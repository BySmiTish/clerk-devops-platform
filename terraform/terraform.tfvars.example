# шаблон переменных для Terraform, который можно безопасно хранить в репозитории.

project_name      = "clerk-devops-platform"
environment       = "dev"
aws_region        = "eu-north-1"
availability_zone = "eu-north-1a"

ssh_key_name      = "your-key-pair-name"
allowed_ssh_cidr  = "YOUR_PUBLIC_IP/32"  # например: "1.2.3.4/32"
instance_type     = "t3.micro"
